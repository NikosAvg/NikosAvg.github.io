&lt;p&gt;&lt;img style=&#34;max-height:1em;max-width:1em&#34; src=&#34;https://nikosavg.github.io/images/xmr.svg&#34;&gt;  88GU1V2z9pbh98CRiZsw9VCmDkACcdysNbdV7g3Tm6Q639zjYDz3HV99g393y3kpiy3iqP2a9PSfbTdgPykPP5eEEUB4bxt&lt;span style=&#34;font-size:small;word-wrap:break-word&#34;&gt;&lt;/span&gt;&lt;/p&gt;
&lt;/center&gt;&lt;/p&gt;
</description>
